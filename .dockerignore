# Keep the build context small and never ship host-built artifacts or secrets.

# Secrets / local state (mounted at runtime, never baked into the image)
.env
.env.*
!.env.example
state/

# Host-built artifacts — rebuilt inside the image for the target OS/arch
.venv/
.uv-cache/
**/node_modules/
dashboard/.next/

# VCS / CI / editor
.git/
.github/
.gitignore

# Python caches
**/__pycache__/
**/*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Not needed at runtime
tests/
docs/
openspec/
**/.DS_Store

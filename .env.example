# Copy to .env and fill in only what you actually use. .env is git-ignored.
# Each integration fails loud at call-time if its key is missing — empty
# placeholders won't break startup.

# --- Database ---
DATABASE_URL=postgresql://localhost:5432/next_signal

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=              # default cloud fallback for local* when OMLX is unreachable
# DEEPSEEK_BASE_URL=          # optional; defaults to https://api.deepseek.com

# --- Local OMLX (Qwen3 via mlx-lm OpenAI-compatible server) ---
# Required when any model profile uses provider: omlx. Missing values raise
# RuntimeError at call time, which triggers the profile's fallback_profile.
OMLX_BASE_URL=
OMLX_API_KEY=

# --- Knowledge: GitHub ingest ---
GITHUB_TOKEN=                  # fine-grained PAT; optional, anonymous is 60 req/h

# --- Info-radar (folocli) ---
# Folo backend token. Either run `npx --yes folocli@latest login` once (token
# saved to ~/.folo/config.json) OR paste a token here. FOLO_TOKEN wins.
FOLO_TOKEN=

# Override folocli launcher (default: ["npx", "--yes", "folocli@0.0.5"]).
# Space-separated. Example to use a globally installed binary:
#   FOLO_CLI_ARGV=folo
# FOLO_CLI_ARGV=

# --- Runtime ---
AGENTOS_PORT=7777
DASHBOARD_URL=http://localhost:3000
PACA_LOG_LEVEL=INFO

# Override default state location (~/.next-signal):
# PACA_STATE_DIR=

# Override agent-staged input files location (defaults to $PACA_STATE_DIR/agent-tmp):
# PACA_AGENT_TMP_DIR=

# --- Knowledge wiki (required for the knowledge pipeline + dashboard wiki views) ---
# Absolute paths to your Obsidian wiki repo and its raw-archive sibling. No
# default — the pipeline and dashboard fail loud if these are unset.
PACA_WIKI_DIR=/path/to/digitalpaca-wiki
PACA_WIKI_RAW_DIR=/path/to/digitalpaca-wiki-raw

# GBrain CLI binary path (only when `gbrain` is not on PATH):
# GBRAIN_BIN=

# OpenCLI entrypoint for WeChat article download — main.js path or wrapper
# script. Required for wechat-source knowledge ingest.
# OPENCLI_BIN=

# Whisper model for bilibili audio transcription fallback (default: base):
# PACA_WHISPER_MODEL=

# Preferred YouTube transcript languages, comma-separated (falls back to en):
# PACA_YOUTUBE_TRANSCRIPT_LANGS=

# GBrain home + dedicated Postgres URL. Dual purpose:
# - Isolated GBrain home for integration / full-flow tests
#   (uv run paca knowledge init-test-gbrain): PACA_GBRAIN_HOME=state/test-gbrain
# - Containerized deployment: docker-compose.yml sets both to wire gbrain's
#   Postgres engine (see docs/containerized-deployment.md)
# PACA_GBRAIN_HOME=state/test-gbrain
# PACA_GBRAIN_DATABASE_URL=       # optional dedicated Postgres URL for GBrain
